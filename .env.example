# ── Django ───────────────────────────────────────────────────────
SECRET_KEY=django-insecure-remplacez-cette-cle-par-une-vraie-valeur-aleatoire
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données (development utilise SQLite par défaut) ──────
# DATABASE_URL=postgresql://user:password@localhost:5432/maketpeyizan

# ── Site ─────────────────────────────────────────────────────────
SITE_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOW_ALL=True

# ── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=AyitiKonekte <info@ayitikonekte.ht>
ADMINS_NOTIFY=

# ── Firebase FCM (notifications push) ───────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON={}

# ── Paiements MonCash ────────────────────────────────────────────
MONCASH_CLIENT_ID=
MONCASH_SECRET_KEY=
MONCASH_ENVIRONMENT=sandbox
PLOPPLOP_CLIENT_ID=

# ── Sentry (monitoring erreurs — prod uniquement) ────────────────
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── Redis (cache — optionnel) ────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
